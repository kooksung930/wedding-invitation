rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /guestbook/{entryId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
          'createdAt',
          'message',
          'name',
          'uid'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 20
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 1
        && request.resource.data.message.size() <= 160
        && request.resource.data.createdAt == request.time;

      allow update: if request.auth != null
        && (!resource.data.keys().hasAny(['isDeleted']) || resource.data.isDeleted != true)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'deletedAt',
          'deletedByUid',
          'isDeleted'
        ])
        && request.resource.data.name == resource.data.name
        && request.resource.data.message == resource.data.message
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.isDeleted == true
        && request.resource.data.deletedByUid == request.auth.uid
        && request.resource.data.deletedAt == request.time;

      allow delete: if false;
    }
  }
}
